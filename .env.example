# Firebase / GCP configuration
# Copy this file to .env and fill in your Firebase project values.
# These are client-side keys — keep them in sync with your Firebase project settings.
# Protect sensitive data using Firebase Security Rules (see firestore.rules).

VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
