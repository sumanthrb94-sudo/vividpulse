// Firestore Security Rules — Vivid Pulse
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User-scoped CRM leads ──────────────────────────────────────────────
    match /users/{userId}/leads/{leadId} {

      // Authenticated owner: full read / write / delete
      allow read, update, delete: if request.auth != null
                                  && request.auth.uid == userId;

      // Public lead capture form: unauthenticated CREATE only.
      // Validates required fields so bots can't write arbitrary data.
      allow create: if request.resource.data.keys().hasAll(['name', 'stage', 'date', 'source'])
                    && request.resource.data.source == 'form'
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 120;
    }

    // ── Deny everything else ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
