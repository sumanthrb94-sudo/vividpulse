// Firestore Security Rules — Vivid Pulse
// Deploy with: firebase deploy --only firestore:rules
//
// Authorization model:
//   - Only authenticated users may read or write their own leads.
//   - Each user's data is isolated under /users/{userId}/leads/{leadId}.
//   - Unauthenticated requests are rejected globally.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User-scoped CRM leads ──────────────────────────────────────────────
    match /users/{userId}/leads/{leadId} {
      // Allow read/write only when the signed-in user's UID matches the path
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Deny all other paths by default ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
